  <visualElements>
    <visualElement>
      <elementName>In</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>OPCODES:
0: AND
1: NAND
2: OR
3: NOR
4: XOR
5: XNOR
6: NOT
7: ADD
8: SUB
9: MUL
10: DIV
11: SHIFT (A shifted by B) left
12: is A == to B
13: NEGITIVE
14: BIT COUNT
15: Bit selector
16: &gt;
17: &lt;
18: NOP: No Operation
19: shift right
20: PRNG, only A is used, A is the seed
Inputs:
A: input 1
B: input 2
Outputs: 
Over: Overflow/remainder
O: output from operation</string>
        </entry>
        <entry>
          <string>rotation</string>
          <rotation rotation="1"/>
        </entry>
        <entry>
          <string>Label</string>
          <string>OPCODE</string>
        </entry>
        <entry>
          <string>Bits</string>
          <int>5</int>
        </entry>
      </elementAttributes>
      <pos x="1220" y="500"/>
    </visualElement>
